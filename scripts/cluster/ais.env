#!/usr/bin/env bash
# 强制经 ais 跳板用 vcctl（覆盖 muxi 本机 kubectl 旁路）
# 用法: source scripts/cluster/ais.env && source scripts/cluster/huawei.env  # 或 muxi.env
export CLUSTER_SSH_HOST=ais-cf3e61a5
export CLUSTER_FORCE_JUMP=1
export CLUSTER_EXEC_MODE=vcctl
# 未 source 具体 profile 时，至少保证跳板名正确
echo "CLUSTER_SSH_HOST=$CLUSTER_SSH_HOST (ais jump; see docs/AIS_JUMP_CLUSTER.md)" >&2
