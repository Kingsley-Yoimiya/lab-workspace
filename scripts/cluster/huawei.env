#!/usr/bin/env bash
# 华为 Ascend 集群 profile —— 与 muxi.env 对称；互不覆盖 kubeconfig
#
# 用法:
#   source scripts/cluster/huawei.env   # 强制切到华为（覆盖先前 muxi.env）
#   ./scripts/cluster/job_helpers.sh pods
#
# 注意: 本文件对 profile 关键变量用强制赋值，避免「先 source muxi 再 source huawei」无效。

export CLUSTER_PROFILE=huawei
export CLUSTER_SSH_HOST="${CLUSTER_SSH_HOST:-weibozhen}"
# 强制绑定华为独立 kubeconfig（不碰默认 ~/.kube/config）
export CLUSTER_KUBECONFIG="/root/.kube/config.huawei-a3-241ceshi"
export CLUSTER_JOB="${CLUSTER_JOB_OVERRIDE:-huawei-8node-copy}"
export CLUSTER_POD="${CLUSTER_POD_OVERRIDE:-${CLUSTER_JOB}-master-0}"
export CLUSTER_IMAGE="${CLUSTER_IMAGE_OVERRIDE:-registry2.d.pjlab.org.cn/ccr-yangxiaolei/mindspeed-llm:openeuler22.03-mindspeed-llm-2.3.0-a3-arm}"

export AFS_ROOT="/afs-a3-241ceshi-shared"
export AFS_WORKSPACE="${AFS_WORKSPACE_OVERRIDE:-${AFS_ROOT}/montyyin/lab-workspace}"
export AFS_CS="${AFS_CS_OVERRIDE:-${AFS_WORKSPACE}/projects/CARD_SCREEN}"
export AFS_RESULTS="${AFS_RESULTS_OVERRIDE:-${AFS_ROOT}/montyyin/results}"

export DEVICES_PER_NODE=16
export CLUSTER_N_WORKERS=6
export CLUSTER_FANOUT_PARALLEL="${CLUSTER_FANOUT_PARALLEL:-4}"
