#!/usr/bin/env bash
# Muxi（沐曦 C550）集群 profile —— 与 huawei.env 对称
#
# 用法:
#   source scripts/cluster/muxi.env   # 强制切到沐曦（覆盖先前 huawei.env）
#   ./scripts/cluster/run_card_screen_muxi.sh all
#
# AFS 写盘约定见 scripts/cluster/AFS_LAYOUT.md
# weight-share 个人前缀默认 yinjinrun.p（勿写 yushan / montyyin）
#
# 双集群并存: 只设 CLUSTER_KUBECONFIG，绝不 cp 覆盖 ~/.kube/config
#
# 本机直连（跳过 weibozhen）：
#   - kubeconfig: ~/.kube/config-muxi-mohe → https://10.140.158.130:49172
#   - TUN 排除了 10/8，kubectl 必须走 Clash mixed-port（见下方 HTTPS_PROXY）

export CLUSTER_PROFILE=muxi
# 走跳板时默认 ais 开发机（见 docs/AIS_JUMP_CLUSTER.md）；本机有 kubeconfig 则优先直连
# 注意：勿沿用环境里残留的 weibozhen；要用旧跳板请显式 CLUSTER_SSH_HOST_OVERRIDE=weibozhen
export CLUSTER_SSH_HOST="${CLUSTER_SSH_HOST_OVERRIDE:-ais-cf3e61a5}"
# 本机优先；跳板上仍可用 /root/.kube/config.muxi-mohe
if [[ -f "${HOME}/.kube/config-muxi-mohe" && "${CLUSTER_FORCE_JUMP:-}" != "1" ]]; then
  export CLUSTER_KUBECONFIG="${CLUSTER_KUBECONFIG_OVERRIDE:-${HOME}/.kube/config-muxi-mohe}"
  export KUBECONFIG="$CLUSTER_KUBECONFIG"
  export CLUSTER_EXEC_MODE="${CLUSTER_EXEC_MODE:-kubectl}"
  # Clash mixed-port：把 10.140.158.130 送进 PJLAB-SH-GW
  # 注意：必须覆盖公司网留下的 NO_PROXY=10.0.0.0/8，否则 kubectl 会直连走 Tailscale 黑洞
  export HTTPS_PROXY="${HTTPS_PROXY:-http://127.0.0.1:7897}"
  export HTTP_PROXY="${HTTP_PROXY:-http://127.0.0.1:7897}"
  export https_proxy="$HTTPS_PROXY"
  export http_proxy="$HTTP_PROXY"
  export NO_PROXY="127.0.0.1,localhost"
  export no_proxy="$NO_PROXY"
  unset ALL_PROXY all_proxy 2>/dev/null || true
else
  export CLUSTER_KUBECONFIG="${CLUSTER_KUBECONFIG_OVERRIDE:-/root/.kube/config.muxi-mohe}"
  export CLUSTER_EXEC_MODE="${CLUSTER_EXEC_MODE:-vcctl}"
fi
export CLUSTER_JOB="${CLUSTER_JOB_OVERRIDE:-yushan-muxi-card-screen-128-cp-copy}"
export CLUSTER_POD="${CLUSTER_POD_OVERRIDE:-${CLUSTER_JOB}-master-0}"

export AFS_ROOT="/afs-a3-weight-share"
export AFS_USER="${AFS_USER_OVERRIDE:-yinjinrun.p}"
export AFS_HOME="${AFS_HOME_OVERRIDE:-${AFS_ROOT}/${AFS_USER}}"
export AFS_WORKSPACE="${AFS_WORKSPACE_OVERRIDE:-${AFS_HOME}/lab-workspace}"
export AFS_CS="${AFS_CS_OVERRIDE:-${AFS_WORKSPACE}/CARD_SCREEN}"
export AFS_RESULTS="${AFS_RESULTS_OVERRIDE:-${AFS_HOME}/results}"
# 他人已验证的 CARD_SCREEN：只读，禁止原地改
export SHARED_CS_READONLY="${SHARED_CS_READONLY_OVERRIDE:-${AFS_ROOT}/yushan/CARD_SCREEN}"

export DEVICES_PER_NODE=8
export CLUSTER_N_WORKERS=15
export CLUSTER_FANOUT_PARALLEL="${CLUSTER_FANOUT_PARALLEL:-6}"
