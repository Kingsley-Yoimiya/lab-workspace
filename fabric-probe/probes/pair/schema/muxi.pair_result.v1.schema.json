{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "muxi.pair_result.v1",
  "type": "object",
  "required": [
    "schema_version",
    "timing_version",
    "round",
    "slot",
    "edge_id",
    "src_index",
    "dst_index",
    "src_pod",
    "dst_pod",
    "src_host",
    "dst_host",
    "src_gpu",
    "dst_gpu",
    "hca",
    "nbytes",
    "iters",
    "iters_s_global_max",
    "bw_GBps",
    "lat_us",
    "pattern_ok"
  ],
  "properties": {
    "schema_version": {"const": "muxi.pair_result.v1"},
    "timing_version": {"const": "p2p.w0.1"},
    "src_gpu": {"const": 0},
    "dst_gpu": {"const": 0},
    "hca": {"const": "xscale_0"},
    "nbytes": {"const": 16777216},
    "pattern_ok": {"const": true},
    "iters_s_global_max": {"type": "array", "minItems": 1}
  }
}
